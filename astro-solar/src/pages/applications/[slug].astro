---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardShell from '../../components/layout/DashboardShell';
import ApplicationPage from '../../components/pages/ApplicationPage';

export function getStaticPaths() {
  return [
    { params: { slug: 'nha-o' } },
    { params: { slug: 'van-phong' } },
    { params: { slug: 'nha-xuong' } },
    { params: { slug: 'khach-san' } },
    { params: { slug: 'nha-hang' } },
  ];
}

const { slug } = Astro.params;
---
<DashboardLayout title="Ứng dụng - EPC Solar">
  <DashboardShell client:load>
    <ApplicationPage applicationType={slug as any} client:idle />
  </DashboardShell>
</DashboardLayout>
