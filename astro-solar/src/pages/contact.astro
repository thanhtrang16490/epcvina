---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import DashboardShell from '../components/layout/DashboardShell';
import ContactPage from '../components/pages/ContactPage';
---

<DashboardLayout
  title="Liên Hệ Tư Vấn Miễn Phí Lắp Điện Mặt Trời | EPC Solar Hà Nội"
  description="Liên hệ EPC Solar để được tư vấn miễn phí lắp đặt điện mặt trời. Hotline: 0988 446 113. Đội ngũ kỹ sư tư vấn tận nơi, báo giá trong 24h."
  keywords="liên hệ EPC Solar, tư vấn điện mặt trời, lắp đặt solar Hà Nội, báo giá điện mặt trời"
  breadcrumbs={[{name: "Trang Chủ", url: "https://epcvina.com"}, {name: "Liên Hệ", url: "https://epcvina.com/contact"}]}
>
  <DashboardShell client:load>
    <ContactPage client:idle />
  </DashboardShell>
</DashboardLayout>
