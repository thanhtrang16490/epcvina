---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import DashboardShell from '../components/layout/DashboardShell';
import EVChargerPage from '../components/pages/EVChargerPage';
---

<DashboardLayout
  title="Trạm Sạc EV Charger - Giải Pháp Sạc Xe Điện | EPC Solar"
  description="Lắp đặt trạm sạc xe điện EV Charger cho gia đình và doanh nghiệp. Tích hợp năng lượng mặt trời, tiết kiệm chi phí vận hành. Tư vấn miễn phí."
  keywords="trạm sạc xe điện, V-GREEN, EV charger, năng lượng mặt trời, sạc xe điện, EPCVINA"
  breadcrumbs={[{name: "Trang Chủ", url: "https://epcvina.com"}, {name: "Dịch Vụ", url: "https://epcvina.com"}, {name: "EV Charger", url: "https://epcvina.com/ev-charger"}]}
>
  <DashboardShell client:load>
    <EVChargerPage client:idle />
  </DashboardShell>
</DashboardLayout>
