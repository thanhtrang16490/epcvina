---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardShell from '../../components/layout/DashboardShell';
import HeaderBar from '../../components/home/HeaderBar';
import BlogHero from '../../components/blog/BlogHero';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Trang Chủ", "item": "https://epcvina.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://epcvina.com/blog" }
  ]
};
---

<DashboardLayout
  title="Blog Điện Mặt Trời - Kiến Thức & Hướng Dẫn | EPC Solar"
  description="Blog chia sẻ kiến thức về điện mặt trời, hướng dẫn lắp đặt, so sánh hệ thống, chi phí và ROI. Cập nhật mới nhất từ EPC Solar."
  keywords="blog điện mặt trời, kiến thức điện mặt trời, hướng dẫn lắp đặt solar, chi phí điện mặt trời, EPC Solar"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <DashboardShell client:load>
  <HeaderBar client:load />
  <main class="min-h-screen bg-gradient-to-br from-red-50 via-white to-green-50 md:pt-16">
    <!-- Blog Hero -->
    <BlogHero client:load />

    <!-- Breadcrumb -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-orange-600 transition-colors duration-200 cursor-pointer">Trang Chủ</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Blog</span>
      </nav>
    </div>

    <!-- Posts Grid -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      {posts.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-xl">Chưa có bài viết nào. Hãy quay lại sau!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-200 ease-in-out cursor-pointer focus-within:ring-2 focus-within:ring-orange-500 focus-within:ring-offset-2 motion-reduce:transition-none">
              <!-- Category color bar -->
              <div class="h-1 bg-gradient-to-r from-orange-500 to-red-600"></div>
              <div class="p-6">
                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="text-xs bg-orange-50 text-orange-700 border border-orange-200 px-2.5 py-1 rounded-full font-medium">
                      #{tag}
                    </span>
                  ))}
                </div>

                <!-- Title -->
                <h2 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2 leading-snug">
                  <a
                    href={`/blog/${post.id}`}
                    class="hover:text-orange-600 transition-colors duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2"
                  >
                    {post.data.title}
                  </a>
                </h2>

                <!-- Description -->
                <p class="text-gray-600 text-sm mb-5 line-clamp-3 leading-relaxed">{post.data.description}</p>

                <!-- Footer -->
                <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-br from-orange-400 to-red-600 flex items-center justify-center text-white text-xs font-bold">
                      E
                    </div>
                    <div>
                      <p class="text-xs font-medium text-gray-700">{post.data.author}</p>
                      <p class="text-xs text-gray-400">{post.data.publishDate.toLocaleDateString('vi-VN')}</p>
                    </div>
                  </div>
                  <a
                    href={`/blog/${post.id}`}
                    class="text-sm text-orange-600 font-semibold hover:text-orange-700 transition-colors duration-200 cursor-pointer focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 rounded"
                  >
                    Đọc thêm →
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- CTA Section -->
      <div class="mt-16 bg-gradient-to-r from-orange-600 to-red-700 rounded-2xl p-8 md:p-12 text-center text-white">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Bạn có câu hỏi về điện mặt trời?</h2>
        <p class="text-orange-100 text-lg mb-6 max-w-xl mx-auto">Đội ngũ kỹ sư EPC Solar sẵn sàng tư vấn miễn phí và báo giá trong 24 giờ.</p>
        <a
          href="/contact"
          class="inline-block bg-white text-orange-700 font-bold px-8 py-3 rounded-xl hover:bg-orange-50 transition-all duration-200 ease-in-out cursor-pointer focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-orange-600 motion-reduce:transition-none"
        >
          Tư Vấn Miễn Phí Ngay →
        </a>
      </div>
    </div>
  </main>
  </DashboardShell>
</DashboardLayout>
