---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import SolutionPage from '../../components/pages/SolutionPage';

export function getStaticPaths() {
  return [
    { params: { slug: 'mai-ton' } },
    { params: { slug: 'mai-ngoi' } },
    { params: { slug: 'mai-bang' } },
  ];
}

const { slug } = Astro.params;
---
<DashboardLayout title="Giải pháp lắp đặt - EPC Solar">
  <SolutionPage roofType={slug as any} client:load />
</DashboardLayout>
