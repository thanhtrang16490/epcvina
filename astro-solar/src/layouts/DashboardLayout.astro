---
interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{name: string, url: string}>;
}

const {
  title = 'EPC Solar - Điện Mặt Trời Trọn Gói | Lắp Đặt Tại Hà Nội',
  description = 'EPC Solar - Chuyên lắp đặt hệ thống điện mặt trời trọn gói cho hộ gia đình và doanh nghiệp. Giải pháp On-Grid & Hybrid tiết kiệm điện đến 90%. Hotline: 0988 446 113.',
  keywords = 'điện mặt trời, lắp đặt điện mặt trời, solar panel, EPC Solar, điện mặt trời Hà Nội, hệ thống điện mặt trời, combo điện mặt trời, on-grid, hybrid',
  ogImage = '/logo-epcvina-solar.png',
  noindex = false,
  breadcrumbs = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "EPC Solar - Công ty Cổ phần Xây lắp EPC Việt Nam",
  "description": description,
  "url": "https://epcvina.com",
  "logo": "https://epcvina.com/logo-epcvina-solar.png",
  "image": "https://epcvina.com/logo-epcvina-solar.png",
  "telephone": "+84988446113",
  "email": "epcvina@hotmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Phòng 315 - Khu TM Chung cư HVQP, Đường Nguyễn Văn Huyên Kéo Dài",
    "addressLocality": "Tây Hồ",
    "addressRegion": "Hà Nội",
    "addressCountry": "VN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "21.0485",
    "longitude": "105.7951"
  },
  "openingHours": "Mo-Sa 08:00-17:30",
  "priceRange": "$$",
  "sameAs": [
    "https://www.facebook.com/epcvina"
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": "21.0285",
      "longitude": "105.8542"
    },
    "geoRadius": "100000"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Hệ thống điện mặt trời",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Lắp đặt điện mặt trời On-Grid"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Lắp đặt điện mặt trời Hybrid"
        }
      }
    ]
  }
};
---

<!DOCTYPE html>
<html lang="vi" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />


    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="EPC Solar" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo-epcvina-solar.png" />

    <!-- Fonts: non-render-blocking via media=print trick -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load only Roboto Flex (primary UI font) eagerly; drop heavy Geist variants -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Preload hero image (LCP) - WebP with PNG fallback -->
    <link rel="preload" as="image" href="/hero-bg.webp" type="image/webp"
      imagesrcset="/hero-bg-768.webp 768w, /hero-bg-1280.webp 1280w, /hero-bg-1920.webp 1920w"
      imagesizes="100vw" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": item.name,
          "item": item.url
        }))
      })} />
    )}

    <!-- Theme color -->
    <meta name="theme-color" content="#f97316" />
    <meta name="author" content="EPC Solar - Công ty CP Xây lắp EPC Việt Nam" />

    <!-- Critical CSS: above-the-fold styles inlined to prevent FOUC -->
    <style is:inline>
      /* Reset & base */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html {
        height: 100%;
        overflow-x: hidden;
        max-width: 100vw;
        -webkit-text-size-adjust: 100%;
        -moz-tab-size: 4;
        tab-size: 4;
        font-family: 'Roboto Flex', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      body {
        min-height: 100%;
        background: linear-gradient(to bottom right, #FEF2F2, #ffffff, #ECFDF5);
        color: #1E293B;
        font-family: 'Roboto Flex', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
        max-width: 100vw;
      }
      /* Layout shell: sidebar + main grid (prevents layout shift) */
      .dashboard-shell {
        display: flex;
        min-height: 100vh;
        position: relative;
      }
      /* Sidebar placeholder: prevent layout shift while JS loads */
      .sidebar-placeholder {
        width: 260px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.6);
      }
      @media (max-width: 1023px) {
        .sidebar-placeholder { display: none; }
      }
      /* Main content area */
      main, .main-content {
        flex: 1;
        min-width: 0;
        overflow-x: hidden;
      }
      /* Prevent invisible text while font loads */
      .font-sans { font-family: 'Roboto Flex', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
      /* Brand color CSS vars (critical — used by header/CTA immediately) */
      :root {
        --color-primary: #D0202A;
        --color-primary-hover: #B01A22;
        --color-secondary-accent: #F5831F;
        --color-charcoal: #4A4F56;
        --color-neutral-900: #0F172A;
        --color-neutral-800: #1E293B;
        --color-neutral-100: #F1F5F9;
        --color-neutral-50: #F8FAFC;
        --background: #F8FAFC;
        --foreground: #1E293B;
        --surface: #FFFFFF;
        --border: #E2E8F0;
      }
    </style>
  </head>
  <body class="min-h-full">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/globals.css";
</style>
